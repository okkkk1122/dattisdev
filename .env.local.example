# کپی کنید: cp .env.local.example .env.local
# سپس: .\scripts\docker-local.ps1 up

NODE_ENV=production
DOMAIN=localhost
LOCAL_HTTP_PORT=8080
LOCAL_DB_PORT=5435
LOCAL_REDIS_PORT=6380

SITE_URL=http://localhost:8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

DB_USER=postgres
DB_NAME=enterprise_db
DB_PASSWORD=localdev
DB_HOST=postgres
DB_PORT=5432

JWT_SECRET=local_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d

REDIS_HOST=redis
REDIS_PORT=6379

NEXT_PUBLIC_API_URL=http://localhost:8080/api
INTERNAL_API_URL=http://backend:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:8080

SMTP_HOST=haraka
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@localhost
CONTACT_EMAIL=info@localhost
MAIL_DOMAIN=localhost
HARAKA_INBOUND_SECRET=local_haraka_secret
