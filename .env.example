# --- تنظیمات شما (Dokploy > Project > Environment) ---
SMTP_HOST=haraka
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@dattisdev.ir
CONTACT_EMAIL=info@dattisdev.ir
MAIL_DOMAIN=dattisdev.ir
HARAKA_INBOUND_SECRET=CHANGE_ME
HARAKA_PUBLIC_SMTP_PORT=2525
HARAKA_PUBLIC_SUBMISSION_PORT=2587
SERVER_IP=YOUR_SERVER_IP

# --- سرور (Dokploy پر می‌کند یا برای لوکال کپی به .env) ---
NODE_ENV=production
DOMAIN=dattisdev.ir
SITE_URL=https://dattisdev.ir
APP_URL=https://dattisdev.ir
FRONTEND_URL=https://dattisdev.ir
CORS_ORIGIN=https://dattisdev.ir

DB_USER=postgres
DB_NAME=enterprise_db
DB_PASSWORD=CHANGE_ME
DB_HOST=postgres
DB_PORT=5432

JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_EXPIRES_IN=7d

REDIS_HOST=redis
REDIS_PORT=6379

NEXT_PUBLIC_API_URL=https://dattisdev.ir/api
INTERNAL_API_URL=http://backend:3001
NEXT_PUBLIC_SOCKET_URL=https://dattisdev.ir
